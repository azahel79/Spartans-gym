NODE_ENV=production
PORT=3000

# MySQL production database
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

# Use a strong random value with at least 32 characters
JWT_SECRET="replace-with-a-very-long-random-secret"
JWT_EXPIRES_IN="7d"

# Public frontend URL. For multiple domains, separate with commas in ALLOWED_ORIGINS.
FRONTEND_URL="https://your-domain.com"
ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# Cloudinary, required if you upload logos/product images in production
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Optional seed credentials for first production admin
SEED_ADMIN_EMAIL="admin@spartansgym.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"
